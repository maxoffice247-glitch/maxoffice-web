# Copy this file to .env.local for local development and fill in real values.
# On Vercel, add these same variable names under Project Settings → Environment Variables.
# Never commit real values — only this file (with placeholders) is safe to commit.

# Zoho SMTP — sends the lead-notification email to cskh@maxoffice.vn for every form submission.
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=

# Google Sheet webhook (Apps Script) — appends every form submission as a row.
GOOGLE_SHEET_WEBHOOK_URL=

# Google Places API — powers the static Google Reviews rating tile.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_ADDRESS=
